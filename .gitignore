# Python bytecode
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/

# Build / packaging artefacts (PyInstaller, Nuitka, setuptools)
build/
dist/
*.build/
*.dist/
*.onefile-build/
*.egg-info/
.eggs/

# Test / type caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Secrets / credentials — review before removing
.env
.env.*
*.key
secret.key

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS cruft
Thumbs.db
desktop.ini
.DS_Store

# KiCad backups, caches & locks (keep .kicad_pcb/.sch/.pro tracked)
*-backups/
fp-info-cache
*.kicad_pro.lck
~*.lck
*-bak
*.kicad_pcb-bak
*.kicad_sch-bak

# Third-party vendor SDK (Waveshare demo + libraries) — kept locally, not in git.
# Re-download from Waveshare's wiki for the ESP32-S3-Touch-LCD-3.5 if needed.
vendor/

# Local "STALE" backups (old fab exports kept on disk, never pushed)
*_STALE_*
